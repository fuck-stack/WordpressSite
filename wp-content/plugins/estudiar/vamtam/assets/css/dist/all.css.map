  position: fixed;
  width: 100%;
}
.vamtam-overlay-trigger--overlay > .vamtam-overlay-element {
  pointer-events: none;
  position: fixed;
  display: block;
  width: 100vw;
  height: 100vh;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 100;
}
