  }
  50% {
    opacity: 0.9;
    transform: scale(1) translateY(-35%);
  }
  70% {
    opacity: 0.9;
    transform: scale(1.2) translateY(35%);
  }
  80% {
    opacity: 1;
    transform: scale(0.89) translateY(0);
  }
  90% {
    opacity: 1;
