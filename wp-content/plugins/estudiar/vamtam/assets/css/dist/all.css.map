.icon,
.icon-a:after,
.icon-b:before {
  font-weight: normal !important;
  font-style: normal !important;
  speak: none;
  display: inline-block;
  min-width: 1em;
  line-height: 1;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}
