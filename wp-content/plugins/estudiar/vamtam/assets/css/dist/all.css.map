/* Scroll to Top */
#scroll-to-top {
  position: fixed;
  z-index: 200;
  opacity: 0;
  bottom: 10px;
  right: 20px;
  width: 1em;
  height: 1em;
  font-size: 2em;
  margin-left: 0px;
  border: none;
  text-shadow: none;
  transition: opacity 0.3s ease-out, color 0.3s ease-out, transform 0.3s ease-out;
  backface-visibility: hidden;
  transform: scale3d(0, 0, 0);
  text-align: center;
  cursor: pointer;
}
#scroll-to-top svg {
  pointer-events: none;
}
#scroll-to-top:hover {
  color: var(--vamtam-accent-color-1);
  transform: translateY(-8px) !important;
}
